// Panther Advertising Operations & Financial Management System
// Database schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  FINANCE
  MARKETING
}

enum CustomerType {
  AGENCY
  DIRECT_COMPANY
}

enum Priority {
  URGENT
  NORMAL
  SCHEDULED
}

enum Platform {
  TWITTER
  TIKTOK
  SNAPCHAT
}

enum CampaignStatus {
  INQUIRY_RECEIVED
  WAITING_FOR_PAYMENT
  PAYMENT_RECEIVED
  SCHEDULED
  ASSIGNED
  POSTED
  WAITING_FOR_RESULTS
  COMPLETED
  FEEDBACK_RECEIVED
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  ONLINE
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
}

enum Satisfaction {
  SATISFIED
  NEUTRAL
  NOT_SATISFIED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  STATUS_CHANGE
}

enum NotificationType {
  CAMPAIGN_TOMORROW
  PAYMENT_OVERDUE
  CAMPAIGN_ASSIGNED
  CAPTURE_MISSING
  FEEDBACK_PENDING
  GENERAL
}

// ---------------------------------------------------------------------------
// Core identity
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  name         String
  nameAr       String?
  email        String    @unique
  passwordHash String
  role         Role      @default(MARKETING)
  // Marketing shift manager — sees their own team's campaigns, results,
  // and statistics rather than only their own assigned work.
  isManager    Boolean   @default(false)
  // Which manager this marketing member reports to (their shift/team).
  managerId    String?
  isActive     Boolean   @default(true)
  avatarUrl    String?
  phone        String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdCampaigns  Campaign[]        @relation("CreatedBy")
  assignedCampaigns Campaign[]        @relation("AssignedTo")
  statusEvents      CampaignEvent[]
  captures          Capture[]
  feedbacks         Feedback[]
  comments          Comment[]
  auditLogs         AuditLog[]
  notifications     Notification[]

  manager     User?  @relation("TeamManager", fields: [managerId], references: [id])
  teamMembers User[] @relation("TeamManager")

  @@index([deletedAt])
  @@index([managerId])
}

// ---------------------------------------------------------------------------
// Customers
// ---------------------------------------------------------------------------

model Company {
  id              String       @id @default(cuid())
  name            String
  nameAr          String?
  type            CustomerType @default(DIRECT_COMPANY)
  city            String?
  industry        String?
  notes           String?
  // Trusted customers may have campaigns proceed before payment is
  // confirmed — set once at the company level, applies to every campaign
  // booked for them.
  trustedCustomer Boolean      @default(false)
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  contacts  Contact[]
  campaigns Campaign[]

  @@index([deletedAt])
  @@index([type])
}

model Contact {
  id         String    @id @default(cuid())
  companyId  String
  name       String
  nameAr     String?
  title      String?
  phone      String?
  whatsapp   String?
  email      String?
  isPrimary  Boolean   @default(true)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company   Company    @relation(fields: [companyId], references: [id])
  campaigns Campaign[]

  @@index([companyId])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// Campaigns
// ---------------------------------------------------------------------------

model Campaign {
  id             String         @id @default(cuid())
  campaignCode   String         @unique // e.g. CMP-2026-0001

  companyId      String
  contactId      String?

  productName      String
  campaignTitle    String
  campaignTitleAr  String?
  description      String?
  brief            String?

  // Advertising platform. numberOfSnaps only applies when platform is SNAPCHAT.
  platform       Platform @default(SNAPCHAT)
  numberOfSnaps  Int      @default(1)
  packageName    String?

  adDate       DateTime?
  postingTime  String?
  priority     Priority  @default(NORMAL)
  // Declared at booking time (e.g. logging a campaign after it already
  // ran) — separate from the step-by-step status pipeline below.
  posted       Boolean   @default(false)

  assignedUserId String?
  status         CampaignStatus @default(INQUIRY_RECEIVED)

  createdById String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id])
  contact     Contact?  @relation(fields: [contactId], references: [id])
  assignedTo  User?     @relation("AssignedTo", fields: [assignedUserId], references: [id])
  createdBy   User      @relation("CreatedBy", fields: [createdById], references: [id])

  finance   CampaignFinance?
  captures  Capture[]
  feedback  Feedback?
  events    CampaignEvent[]
  comments  Comment[]

  @@index([deletedAt])
  @@index([status])
  @@index([companyId])
  @@index([assignedUserId])
  @@index([adDate])
}

// One-to-one financial record — kept in its own table so it can be
// excluded entirely from any query/serialization reachable by Marketing.
model CampaignFinance {
  id           String   @id @default(cuid())
  campaignId   String   @unique

  price          Decimal  @db.Decimal(12, 2) @default(0)
  discount       Decimal  @db.Decimal(12, 2) @default(0)
  vat            Decimal  @db.Decimal(12, 2) @default(0)
  finalAmount    Decimal  @db.Decimal(12, 2) @default(0)

  invoiceNumber  String?
  paymentMethod  PaymentMethod?
  paymentStatus  PaymentStatus  @default(PENDING)

  depositDate         DateTime?
  expectedDepositDate DateTime?
  amountPaid          Decimal   @db.Decimal(12, 2) @default(0)
  remainingBalance    Decimal   @db.Decimal(12, 2) @default(0)
  transactionRef      String?

  invoiceAttachmentUrl String?
  receiptAttachmentUrl String?
  financialNotes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([paymentStatus])
}

model Capture {
  id             String   @id @default(cuid())
  campaignId     String
  numberOfCaptures Int?
  engagement     String?
  comments       String?
  screenshotUrl  String?
  completionTime DateTime?
  createdById    String
  createdAt      DateTime @default(now())

  campaign  Campaign @relation(fields: [campaignId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  @@index([campaignId])
}

model Feedback {
  id                String       @id @default(cuid())
  campaignId        String       @unique
  satisfaction      Satisfaction @default(NEUTRAL)
  rating            Int          @default(3) // 1-5
  notes             String?
  futureCooperation Boolean      @default(true)
  recordedById      String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  campaign   Campaign @relation(fields: [campaignId], references: [id])
  recordedBy User     @relation(fields: [recordedById], references: [id])
}

// Status-change timeline entries
model CampaignEvent {
  id         String          @id @default(cuid())
  campaignId String
  fromStatus CampaignStatus?
  toStatus   CampaignStatus
  note       String?
  userId     String
  createdAt  DateTime        @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([campaignId])
}

model Comment {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  body       String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([campaignId])
}

// ---------------------------------------------------------------------------
// System
// ---------------------------------------------------------------------------

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
